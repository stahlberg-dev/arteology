---
const {
  tag = 'h2',
  class: className,
  size = 'md',
  ...attrs
} = Astro.props;

const allowedTags = ['h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'p', 'div'];
const Tag = allowedTags.includes(tag) ? tag : 'h2';

const classes = [
  'base-title',
  `base-title_size_${size}`,
  'js-title',
  className,
];
---

<Tag
  class:list={classes}
  {...attrs}
>
  <slot />
</Tag>

<script>
  import { gsap } from '../scripts/helpers/gsap.js';

  function titleAnimation() {
    const mm = gsap.matchMedia();

    function titleAnimationHandler() {
      gsap.utils.toArray('.js-title').forEach((title) => {
        const tween = gsap.from(title, {
          opacity: 0,
          y: '5rem',
          duration: 2,
          ease: 'power4.out',
          scrollTrigger: {
            trigger: title,
            start: "bottom bottom",
          },
          onStart: () => {
            title.style.pointerEvents = 'none';
          },
          onComplete() {
            title.style.pointerEvents = '';
            tween.scrollTrigger?.kill();
            tween.kill();
          },
          onInterrupt: () => {
            title.style.pointerEvents = '';
          },
        });
      });
    }

    mm.add('(max-width: 767.98px)', titleAnimationHandler);

    mm.add('(min-width: 768px) and (max-width: 1199.98px)', titleAnimationHandler);

    mm.add('(min-width: 1200px)', titleAnimationHandler);

    document.addEventListener('astro:before-swap', () => {
      mm.revert();
    }, { once: true });
  }

  titleAnimation();
</script>

<style lang="scss" is:global>
  .base-title {
    $element: &;

    &_size_md {
      @include h2;
    }

    &_size_sm {
      @include h3;
    }
  }
</style>
