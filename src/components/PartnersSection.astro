---
import { BASE } from '../scripts/helpers/constants.js';
const { class: className, ...attrs } = Astro.props;

const classes = ['partners-section', className];
---

<section
  class:list={classes}
  {...attrs}
>
  <div class="partners-section__container">
    <div class="partners-section__top">
      <h2 class="partners-section__title js-partners-title">
        Официальный партнер ВТБ&nbsp;Private
      </h2>

      <img
        class="partners-section__vtb-logo js-vtb-logo"
        src={`${BASE}images/partners-section/vtb-logo.svg`}
        alt="vtb logo"
        loading="lazy"
      />
    </div>

    <div class="partners-section__bottom">
      <div class="partners-section__info">
        <h3 class="partners-section__info-title js-partners-subtitle">
          аккредитованный провайдер арт- экспертизы
          для&nbsp;клиентов сегмента HNWI
          и&nbsp;Family&nbsp;Offices банка&nbsp;ВТБ
        </h3>

        <p class="partners-section__info-text js-partners-text">
          Мы обеспечиваем интеграцию искусства в&nbsp;структуру
          wealth-менеджмента: от&nbsp;оценки залоговых активов
          до&nbsp;сопровождения трансграничных сделок в&nbsp;соответствии
          с&nbsp;процедурами банковского комплаенса (KYC/AML).
        </p>
      </div>

      <picture class="partners-section__image-wrapper js-partners-image">
        <img
          class="partners-section__image"
          src={`${BASE}images/partners-section/partners-image.webp`}
          alt="изображение"
          loading="lazy"
        />
      </picture>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  function partnersSectionAnimation() {
    gsap.registerPlugin(ScrollTrigger, SplitText);

    const mm = gsap.matchMedia();
    let splitTitle, splitSubitle, splitText;

    function sectionAnimations() {
      splitTitle = SplitText.create('.js-partners-title', { type: 'chars,words' });
      splitSubitle = SplitText.create('.js-partners-subtitle', { type: 'words,lines' });
      splitText = SplitText.create('.js-partners-text', { type: 'words,lines' });

      gsap.from(splitTitle.chars, {
        opacity: 0,
        // x: '3rem',
        // y: '-2rem',
        duration: 0.07,
        ease: 'power4.out',
        stagger: 0.07,
        scrollTrigger: {
          trigger: '.js-partners-title',
          start: "bottom bottom",
        },
      });
  
      gsap.from(splitSubitle.lines, {
        opacity: 0,
        y: '5rem',
        duration: 1,
        ease: 'power4.out',
        stagger: 0.07,
        scrollTrigger: {
          trigger: '.js-partners-subtitle',
          start: "bottom bottom",
        },
      });

      gsap.from(splitText.lines, {
        opacity: 0,
        y: '5rem',
        duration: 1,
        ease: 'power4.out',
        stagger: 0.07,
        scrollTrigger: {
          trigger: '.js-partners-text',
          start: "bottom bottom",
        },
      });

      gsap.from('.js-vtb-logo', {
        opacity: 0,
        y: '3rem',
        duration: 1,
        delay: 0.5,
        ease: 'power4.out',
        scrollTrigger: {
          trigger: '.js-vtb-logo',
          start: "bottom-=3rem bottom",
        },
      });
    }
    
    mm.add('(max-width: 767.98px)', () => {
      sectionAnimations();

      gsap.from('.js-partners-image', {
        opacity: 0,
        duration: 2,
        ease: 'none',
        scrollTrigger: {
          trigger: '.js-partners-image',
          start: "top+=30% bottom",
        },
      });

      return () => {
        splitTitle.revert();
        splitSubitle.revert();
        splitText.revert();
      };
    });

    mm.add('(min-width: 768px) and (max-width: 1199.98px)', () => {
      sectionAnimations();

      gsap.from('.js-partners-image', {
        opacity: 0,
        duration: 3,
        ease: 'none',
        scrollTrigger: {
          trigger: '.js-partners-image',
          start: "bottom bottom",
        },
      });

      return () => {
        splitTitle.revert();
        splitSubitle.revert();
        splitText.revert();
      };
    });

    mm.add('(min-width: 1200px)', () => {
      sectionAnimations();

      gsap.from('.js-partners-image', {
        opacity: 0,
        duration: 3,
        ease: 'none',
        scrollTrigger: {
          trigger: '.js-partners-image',
          start: "bottom bottom",
        },
      });

      return () => {
        splitTitle.revert();
        splitSubitle.revert();
        splitText.revert();
      };
    });
  }

  partnersSectionAnimation();
</script>

<style lang="scss" is:global>
  .partners-section {
    $element: &;

    padding: rem(80) 0;
    background-color: $dark;
    color: $light;

    @media #{$desktop-sm} {
      padding: rem(120) 0;
    }

    &__container {
      @include base-container;

      @media #{$tablet} {
        padding-top: rem(80);
        padding-bottom: rem(80);
      }

      @media #{$desktop-sm} {
        padding-top: rem(120);
        padding-bottom: 0;
      }
    }

		&__top {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-items: flex-start;
      gap: rem(60);

      @media #{$tablet} {
        flex-direction: row;
      }

      @media #{$desktop-sm} {
        margin-left: rem(232);
      }
    }

		&__title {
      @media #{$tablet} {
        @include h3;

        flex-shrink: 0;
        width: rem(460);
      }
		}

		&__vtb-logo {
      flex-shrink: 0;
      width: rem(126);

      @media #{$tablet} {
        width: rem(170);
      }
		}

		&__bottom {
      display: flex;
      flex-direction: column;
      gap: rem(48);
      margin-top: rem(60);

      @media #{$tablet} {
        flex-direction: row-reverse;
        justify-content: flex-end;
        align-items: flex-start;
        gap: rem(184);
        margin-top: rem(140);
      }

      @media #{$desktop-sm} {
        gap: rem(394);
        margin-top: rem(148);
      }
		}

		&__info {
      @media #{$desktop-sm} {
        max-width: rem(444);
      }
		}

		&__info-title {
      @include h4;
		}

		&__info-text {
      margin: rem(48) rem(48) 0 0;

      @media #{$tablet} {
        margin: rem(72) rem(72) 0 0;
      }

      @media #{$desktop-sm} {
        margin: rem(72) 0 0 0;
      }
		}

		&__image-wrapper {
      flex-shrink: 0;
      width: 100%;
      height: rem(440);

      @media #{$tablet} {
        width: rem(306);
        height: rem(342);
      }

      @media #{$desktop-sm} {
        margin-top: rem(186);
        width: rem(304);
        height: rem(382);
      }
		}

		&__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
		}

    &__text {
      margin-top: rem(60);
      
      @media #{$tablet} {
        margin-top: rem(72);
        margin-left: rem(490);
        max-width: rem(444);
      }

      @media #{$desktop-sm} {
        margin-left: rem(698);
      }
    }
  }
</style>
