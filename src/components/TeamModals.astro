---
import { BASE } from '../scripts/helpers/constants.js';
import TeamModal from '../components/TeamModal.astro';

const teamModalsList = [
  {
    name: 'team-member-1',
    content: {
      imageUrl: `${BASE}images/team-section/portraits/portrait-1-desktop.webp`,
      title: 'Александр Балашов',
      subtitle: 'Co-Founder &&nbsp;Chief Curator',
      text: `
        Ведущий эксперт по&nbsp;русскому и&nbsp;советскому искусству XX&nbsp;века.
        Обеспечивает искусствоведческую экспертизу
        и&nbsp;стратегическое кураторство частных и&nbsp;корпоративных фондов.
      `,
      paragraphs: [
        {
          title: 'Банковский уровень коллекционирования',
          text: `
            Куратор собрания живописи «ЮниКредит Банка». Знает
            специфику интеграции искусства в&nbsp;корпоративную структуру
            и&nbsp;стандарты банковского комплаенса
            в&nbsp;отношении культурных ценностей.
          `,
        },
        {
          title: 'Фундаментальная экспертиза',
          text: `
            Специалист по&nbsp;"сложным" периодам
            искусства (от&nbsp;авангарда до&nbsp;постмодерна),
            автор монографий, книг и&nbsp;художественных альбомов.
          `,
        },
        {
          title: 'Публичный авторитет',
          text: `
            Лектор ведущих площадок (НИУ ВШЭ, Центр Вознесенского),
            член редакционного совета «Художественного журнала»
            (ХЖ) и&nbsp;альманахов по&nbsp;искусству.
          `,
        },
        {
          title: 'Визионер',
          text: `
            Ведущий ресурса «Артеология» с&nbsp;2010 года, исследующий
            искусство как&nbsp;метод оценки времени&nbsp;— подход,
            позволяющий прогнозировать интерес
            к&nbsp;тем или&nbsp;иным периодам в&nbsp;будущем.
          `,
        },
      ],
    }
  },
  {
    name: 'team-member-2',
    content: {
      imageUrl: `${BASE}images/team-section/portraits/portrait-2-desktop.webp`,
      title: 'Залина Самсонова',
      subtitle: 'Founder &&nbsp;Creative Director',
      text: `
        Культурный предприниматель и&nbsp;искусствовед,
        специализирующийся на&nbsp;стратегическом
        планировании и&nbsp;институциональном продвижении коллекций.
      `,
      paragraphs: [
        {
          title: 'Институциональный лоббизм&nbsp;(GR)',
          text: `
            Прямые контакты и&nbsp;опыт партнерства с&nbsp;главными музеями
            России (Третьяковская галерея, Пушкинский музей, Манеж)
            и&nbsp;Министерством культуры. Это критически важно
            для&nbsp;капитализации коллекций через&nbsp;выставки и&nbsp;публикации.
          `,
        },
        {
          title: 'Международный менеджмент',
          text: `
            Опыт реализации проектов в&nbsp;юрисдикциях Великобритании,
            Швейцарии, Франции, Турции и Бенилюкса.
            Понимание специфики западного арт-рынка изнутри.
          `,
        },
        {
          title: 'Комплексный Art Management',
          text: `
            Полный цикл сопровождения (Full-Service): от&nbsp;разработки
            концепции и&nbsp;сценария коллекции до&nbsp;решения
            вопросов логистики, страхования и&nbsp;технического монтажа.
          `,
        },
        {
          title: 'Междисциплинарный подход',
          text: `
            Создание проектов на&nbsp;стыке изобразительного искусства, театра и&nbsp;кино.
            Умение «упаковать» коллекцию как&nbsp;медийный продукт.
          `,
        },
      ],
    }
  },
  {
    name: 'team-member-3',
    content: {
      imageUrl: `${BASE}images/team-section/portraits/portrait-3-desktop.webp`,
      title: 'Денис Самсонов',
      subtitle: 'Managing Partner &&nbsp;Chief&nbsp;Development&nbsp;Officer ',
      text: `
        Ключевой стратег компании, отвечающий
        за&nbsp;развитие направления арт-инвестиций и&nbsp;интеграцию
        искусства в&nbsp;структуру частного капитала (Wealth Management).
      `,
      paragraphs: [
        {
          title: 'Синтез финансов и&nbsp;искусства',
          text: `
            Уникальное сочетание диплома по&nbsp;международной
            экономике и&nbsp;степени Masters in&nbsp;Wealth Management
            со&nbsp;специализированной подготовкой в&nbsp;области Art&nbsp;Banking.
          `,
        },
        {
          title: 'Профессиональная оценка',
          text: `
            Дипломированный специалист по&nbsp;оценке
            движимого имущества и&nbsp;предметов искусства.
            Гарант объективности и&nbsp;"чистоты" сделок Arteology.
          `,
        },
        {
          title: 'Международный опыт',
          text: `
            Глубокая экспертиза, наработанная в&nbsp;сотрудничестве
            с&nbsp;ведущими музеями Ближнего Востока
            и&nbsp;через прямое взаимодействие с&nbsp;зарубежным
            арт-рынком на&nbsp;выставках уровня
            TEFAF (Маастрихт) и&nbsp;Art&nbsp;Basel.
          `,
        },
        {
          title: 'Академический фундамент',
          text: `
            Выпускник профильных программ TANG
            и&nbsp;образовательных курсов аукционного дома&nbsp;Bonhams.
          `,
        },
      ],
    }
  },
];
---

<Fragment>
  {teamModalsList.map((teamModal) => (
    <TeamModal
      name={teamModal.name}
      content={teamModal.content}
    />
  ))}
</Fragment>
